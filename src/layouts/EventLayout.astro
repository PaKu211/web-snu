---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import EventStatus from "@/components/EventStatus.astro"
import EventCountdown from "@/components/EventCountdown.astro"
import { formatDate } from "@/lib/utils"
import coverTemple from "@/assets/cover_temple.jpg"

interface Props {
  entry: CollectionEntry<"events">
}

const { entry } = Astro.props
const { title, description, startDate, endDate, location, cover, draft } = entry.data

const now = new Date()
const isUpcoming = startDate > now
const formattedStartDate = formatDate(startDate)
const formattedEndDate = endDate ? formatDate(endDate) : undefined

// Format time range
const formatTime = (d: Date) => {
  return new Intl.DateTimeFormat("id-ID", {
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  }).format(d)
}
const timeRange = `${formatTime(startDate)} WITA${endDate ? ` - ${formatTime(endDate)} WITA` : ""}`

const finalCover = cover || coverTemple
---

<BaseLayout title={title} description={description} image={cover ? undefined : "/og-default.png"}>
  <div class="mx-auto max-w-4xl px-4 pb-16 pt-8 sm:px-6">
    <Breadcrumb items={[{ label: "Events", href: "/events" }, { label: title }]} />

    <div class="mt-5 flex flex-wrap items-center gap-2">
      <EventStatus startDate={startDate} endDate={endDate} />
      {draft && (
        <span class="inline-flex items-center rounded-full bg-[var(--color-accent)]/15 px-2.5 py-0.5 text-[9px] font-mono uppercase tracking-[0.1em] text-[var(--color-accent)] border border-[var(--color-accent)]/20">
          Draf
        </span>
      )}
    </div>

    <h1 class="mt-4 font-serif text-3xl font-medium leading-tight sm:text-4xl md:text-5xl text-[var(--color-foreground)] text-balance">
      {title}
    </h1>
    <p class="mt-4 text-base sm:text-lg leading-relaxed text-[var(--color-muted)] text-pretty">{description}</p>

    <!-- Main Visual / Cover Image -->
    {
      finalCover && (
        <Image
          src={finalCover}
          alt={`Visual event ${title}`}
          loading="eager"
          widths={[480, 768, 1200]}
          sizes="(min-width: 768px) 768px, 100vw"
          class="my-8 aspect-[21/9] w-full rounded-[var(--radius-lg)] object-cover border border-[var(--color-border)]/20 shadow-[0_8px_24px_rgba(0,0,0,0.5)]"
        />
      )
    }

    <!-- Event Quick Details & Actions -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 my-8">
      <div class="p-1.5 rounded-[1.75rem] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[0_12px_24px_-12px_rgba(0,0,0,0.3)] md:col-span-2">
        <div class="space-y-5 rounded-[1.375rem] bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/40 p-5 sm:p-6 h-full">
          <h2 class="font-serif text-xl font-medium border-b border-[var(--color-border)]/20 pb-2 text-[var(--color-foreground)]">Informasi Acara</h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1">
            <span class="text-xs uppercase tracking-wider text-[var(--color-muted)] font-medium">Tanggal</span>
            <p class="text-sm font-semibold text-[var(--color-foreground)]">
              {formattedStartDate} {formattedEndDate && formattedEndDate !== formattedStartDate ? ` s.d. ${formattedEndDate}` : ""}
            </p>
          </div>
          
          <div class="space-y-1">
            <span class="text-xs uppercase tracking-wider text-[var(--color-muted)] font-medium">Waktu</span>
            <p class="text-sm font-semibold text-[var(--color-foreground)]">{timeRange}</p>
          </div>

          <div class="sm:col-span-2 space-y-1 border-t border-[var(--color-border)]/50 pt-3">
            <span class="text-xs uppercase tracking-wider text-[var(--color-muted)] font-medium">Lokasi</span>
            <p class="text-sm font-semibold text-[var(--color-foreground)] flex items-center gap-1.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-primary)]">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              {location}
            </p>
          </div>
        </div>
      </div>
      </div>

      <div>
        {isUpcoming && <EventCountdown startDate={startDate} class="h-full justify-center" />}
      </div>
    </div>

    <!-- Event Body Content -->
    <div class="prose max-w-none border-t border-[var(--color-border)] pt-8">
      <slot />
    </div>
  </div>
</BaseLayout>
