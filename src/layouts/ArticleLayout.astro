---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import ArticleMeta from "@/components/ArticleMeta.astro"
import TableOfContents from "@/components/TableOfContents.astro"
import RelatedArticles from "@/components/RelatedArticles.astro"
import ReadingProgress from "@/components/ReadingProgress.astro"
import TagBadge from "@/components/TagBadge.astro"
import SeriBadge from "@/components/SeriBadge.astro"
import WalineComments from "@/components/WalineComments.astro"
import { buildToc, readingTime, seriLabel } from "@/lib/utils"
import type { TocItem } from "@/lib/utils"
import coverTemple from "@/assets/cover_temple.jpg"
import coverMeditation from "@/assets/cover_meditation.jpg"

interface Props {
  entry: CollectionEntry<"artikel">
  headings: { depth: number; slug: string; text: string }[]
  rawBody: string
  related: CollectionEntry<"artikel">[]
}

const { entry, headings, rawBody, related } = Astro.props
const { title, description, author, publishDate, tags, seri, cover, draft, sourceUrl } = entry.data
const minutes = readingTime(rawBody)
const toc: TocItem[] = buildToc(headings)

const fallbackCovers = [
  coverTemple,
  coverMeditation,
]
const finalCover = cover || fallbackCovers[entry.id.charCodeAt(0) % fallbackCovers.length]
---

<BaseLayout title={title} description={description} type="article" image={cover ? undefined : "/og-default.png"}>
  <ReadingProgress />

  <div class="mx-auto max-w-3xl px-4 pb-16 pt-8 sm:px-6">
    <Breadcrumb items={[{ label: "Artikel", href: "/artikel" }, { label: title }]} />

    <header class="mb-8">
      <div class="mb-5 flex flex-wrap items-center gap-1.5">
        {seri && <SeriBadge seri={seri} />}
        {tags && tags.map(tag => {
           let colorClass = "bg-neutral-800 text-neutral-300";
           if (tag === "niskala" || tag === "lore" || tag === "history") colorClass = "bg-[#b85a3c]/15 text-[#e68a6c] border border-[#b85a3c]/25";
           else if (tag === "sekala" || tag === "meditation" || tag === "nature") colorClass = "bg-[#1aa79b]/15 text-[#1aa79b] border border-[#1aa79b]/25";
           else if (tag === "outbound" || tag === "space-grotesk" || tag === "astronomy") colorClass = "bg-[#385e54]/15 text-[#82b4a5] border border-[#385e54]/25";
           else if (tag === "english-hours" || tag === "mythology") colorClass = "bg-[#d5c39a]/15 text-[#d5c39a] border border-[#d5c39a]/25";
           return (
             <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-[9px] font-mono uppercase tracking-[0.1em] ${colorClass}`}>
               {tag}
             </span>
           )
        })}
        {draft && (
          <span class="inline-flex items-center rounded-full bg-[var(--color-accent)]/15 px-2.5 py-0.5 text-[9px] font-mono uppercase tracking-[0.1em] text-[var(--color-accent)] border border-[var(--color-accent)]/20">
            Draf
          </span>
        )}
      </div>

      <h1 class="font-serif text-3xl font-medium leading-tight text-balance sm:text-4xl text-[var(--color-foreground)]">
        {title}
      </h1>
      <p class="mt-4 text-base sm:text-lg leading-relaxed text-[var(--color-muted)] text-pretty">{description}</p>

      <ArticleMeta author={author} publishDate={publishDate} minutes={minutes} class="mt-5" />

      <!-- Text Size and Font Switcher Widget Toolbar -->
      <div class="mt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-y border-[var(--color-border)]/20 py-3 text-xs text-[var(--color-muted)]">
        <!-- Font family switcher -->
        <div class="flex items-center justify-between gap-3 sm:justify-start">
          <div class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-primary)]">
              <polyline points="4 7 4 4 20 4 20 7"></polyline>
              <line x1="9" y1="20" x2="15" y2="20"></line>
              <line x1="12" y1="4" x2="12" y2="20"></line>
            </svg>
            <span class="font-serif">Gaya Huruf</span>
          </div>
          <div class="flex items-center gap-1 bg-[var(--color-surface-2)]/60 rounded-full p-1 border border-[var(--color-border)]/40">
            <button 
              type="button"
              id="font-serif" 
              class="h-7 px-3 rounded-full flex items-center justify-center text-[10px] uppercase font-serif tracking-wider transition-all cursor-pointer"
              title="Font Serif (Klasik)"
            >
              Serif
            </button>
            <button 
              type="button"
              id="font-sans" 
              class="h-7 px-3 rounded-full flex items-center justify-center text-[10px] uppercase font-sans tracking-wider transition-all cursor-pointer"
              title="Font Sans (Modern)"
            >
              Sans
            </button>
            <button 
              type="button"
              id="font-mono" 
              class="h-7 px-3 rounded-full flex items-center justify-center text-[10px] uppercase font-mono tracking-wider transition-all cursor-pointer"
              title="Font Mono (Kode)"
            >
              Mono
            </button>
          </div>
        </div>

        <!-- Text size changer -->
        <div class="flex items-center justify-between gap-3 sm:justify-end">
          <div class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-primary)]">
              <path d="M4 7V4h16v3M9 20h6M12 4v16"/>
            </svg>
            <span class="font-serif">Ukuran Teks</span>
          </div>
          <div class="flex items-center gap-1 bg-[var(--color-surface-2)]/60 rounded-full p-1 border border-[var(--color-border)]/40">
            <button 
              type="button"
              id="text-dec" 
              class="h-7 w-7 rounded-full flex items-center justify-center text-xs font-mono text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-all cursor-pointer"
              title="Perkecil tulisan (A-)"
            >
              A-
            </button>
            <button 
              type="button"
              id="text-normal" 
              class="h-7 px-3 rounded-full flex items-center justify-center text-[10px] uppercase font-mono tracking-wider font-semibold text-[var(--color-primary)] bg-[var(--color-surface)] border border-[var(--color-border)]/20 transition-all cursor-pointer"
              title="Ukuran normal"
            >
              Normal
            </button>
            <button 
              type="button"
              id="text-inc" 
              class="h-7 w-7 rounded-full flex items-center justify-center text-xs font-mono text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-all cursor-pointer"
              title="Perbesar tulisan (A+)"
            >
              A+
            </button>
          </div>
        </div>
      </div>
    </header>

    {
      finalCover && (
        <Image
          src={finalCover}
          alt={`Ilustrasi untuk artikel ${title}`}
          loading="eager"
          widths={[480, 768, 1200]}
          sizes="(min-width: 768px) 768px, 100vw"
          class="mb-10 aspect-[21/9] w-full rounded-[var(--radius-lg)] object-cover shadow-[0_8px_24px_rgba(0,0,0,0.5)] border border-[var(--color-border)]/20"
        />
      )
    }

    <div class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-10">
      <div class="prose min-w-0">
        <slot />
      </div>

      {
        toc.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24">
              <TableOfContents toc={toc} />
            </div>
          </aside>
        )
      }
    </div>

    {
      tags.length > 0 && (
        <div class="mt-12 flex flex-wrap items-center gap-2 border-t border-[var(--color-border)] pt-6">
          <span class="text-sm text-[var(--color-muted)]">Tag:</span>
          {tags.map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      )
    }

    {
      sourceUrl && (
        <p class="mt-4 text-xs text-[var(--color-muted)]">
          Tulisan ini awalnya terbit di{" "}
          <a href={sourceUrl} class="underline hover:text-[var(--color-foreground)]" rel="noopener noreferrer" target="_blank">
            sumber aslinya
          </a>
          .
        </p>
      )
    }

    <WalineComments path={`/artikel/${entry.id}`} />

    <RelatedArticles entries={related} />
  </div>

  <script>
    function initArticleControls() {
      const prose = document.querySelector('.prose');
      const decBtn = document.getElementById('text-dec');
      const normalBtn = document.getElementById('text-normal');
      const incBtn = document.getElementById('text-inc');

      const fontSerifBtn = document.getElementById('font-serif');
      const fontSansBtn = document.getElementById('font-sans');
      const fontMonoBtn = document.getElementById('font-mono');

      if (!prose) return;

      // --- TEXT SIZE ---
      const sizeClasses = ['prose-sm', 'prose-base', 'prose-lg', 'prose-xl', 'prose-2xl'];
      let currentSizeIndex = parseInt(localStorage.getItem('preferred-prose-size-index') ?? '2');
      if (isNaN(currentSizeIndex) || currentSizeIndex < 0 || currentSizeIndex >= sizeClasses.length) {
        currentSizeIndex = 2;
      }

      function updateSize() {
        sizeClasses.forEach(c => prose.classList.remove(c));
        prose.classList.add(sizeClasses[currentSizeIndex]);

        if (decBtn && incBtn) {
          decBtn.style.opacity = currentSizeIndex === 0 ? '0.4' : '1';
          decBtn.style.pointerEvents = currentSizeIndex === 0 ? 'none' : 'auto';
          
          incBtn.style.opacity = currentSizeIndex === sizeClasses.length - 1 ? '0.4' : '1';
          incBtn.style.pointerEvents = currentSizeIndex === sizeClasses.length - 1 ? 'none' : 'auto';
        }

        localStorage.setItem('preferred-prose-size-index', String(currentSizeIndex));
      }

      if (decBtn && normalBtn && incBtn) {
        decBtn.addEventListener('click', () => {
          if (currentSizeIndex > 0) {
            currentSizeIndex--;
            updateSize();
          }
        });

        incBtn.addEventListener('click', () => {
          if (currentSizeIndex < sizeClasses.length - 1) {
            currentSizeIndex++;
            updateSize();
          }
        });

        normalBtn.addEventListener('click', () => {
          currentSizeIndex = 2; // prose-lg as normal
          updateSize();
        });
      }

      updateSize();

      // --- FONT FAMILY ---
      const fontClasses = ['prose-font-serif', 'prose-font-sans', 'prose-font-mono'];
      let currentFont = localStorage.getItem('preferred-prose-font') ?? 'serif';
      if (currentFont !== 'serif' && currentFont !== 'sans' && currentFont !== 'mono') {
        currentFont = 'serif';
      }

      function updateFont() {
        fontClasses.forEach(c => prose.classList.remove(c));
        prose.classList.add(`prose-font-${currentFont}`);

        // Update button active state classes
        const fontBtns = {
          serif: fontSerifBtn,
          sans: fontSansBtn,
          mono: fontMonoBtn
        };

        Object.keys(fontBtns).forEach(key => {
          const btn = fontBtns[key];
          if (!btn) return;
          if (key === currentFont) {
            btn.classList.add('text-[var(--color-primary)]', 'bg-[var(--color-surface)]', 'border', 'border-[var(--color-border)]/20');
            btn.classList.remove('text-[var(--color-muted)]');
          } else {
            btn.classList.remove('text-[var(--color-primary)]', 'bg-[var(--color-surface)]', 'border', 'border-[var(--color-border)]/20');
            btn.classList.add('text-[var(--color-muted)]');
          }
        });

        localStorage.setItem('preferred-prose-font', currentFont);
      }

      if (fontSerifBtn && fontSansBtn && fontMonoBtn) {
        fontSerifBtn.addEventListener('click', () => {
          currentFont = 'serif';
          updateFont();
        });
        fontSansBtn.addEventListener('click', () => {
          currentFont = 'sans';
          updateFont();
        });
        fontMonoBtn.addEventListener('click', () => {
          currentFont = 'mono';
          updateFont();
        });
      }

      updateFont();
    }

    // Load initial controls state
    initArticleControls();
    
    // Support page transitions
    document.addEventListener('astro:after-swap', initArticleControls);
  </script>
</BaseLayout>
