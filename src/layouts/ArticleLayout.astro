---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import ArticleMeta from "@/components/ArticleMeta.astro"
import TableOfContents from "@/components/TableOfContents.astro"
import RelatedArticles from "@/components/RelatedArticles.astro"
import ReadingProgress from "@/components/ReadingProgress.astro"
import TagBadge from "@/components/TagBadge.astro"
import SeriBadge from "@/components/SeriBadge.astro"
import WalineComments from "@/components/WalineComments.astro"
import { buildToc, readingTime } from "@/lib/utils"
import type { TocItem } from "@/lib/utils"
import coverTemple from "@/assets/cover_temple.jpg"
import coverMeditation from "@/assets/cover_meditation.jpg"

interface Props {
  entry: CollectionEntry<"artikel">
  headings: { depth: number; slug: string; text: string }[]
  rawBody: string
  related: CollectionEntry<"artikel">[]
}

const { entry, headings, rawBody, related } = Astro.props
const { title, description, author, publishDate, tags, seri, cover, draft, sourceUrl } = entry.data
const minutes = readingTime(rawBody)
const toc: TocItem[] = buildToc(headings)

const finalCover = cover
---

<BaseLayout title={title} description={description} type="article" image={cover ? undefined : "/og-default.png"}>
  <ReadingProgress />

  <div class:list={[
    "mx-auto px-4 pb-24 pt-12 sm:px-6 lg:px-8",
    toc.length > 0 ? "max-w-5xl" : "max-w-3xl"
  ]}>
    <!-- Breadcrumb with a fade-in delay -->
    <div class="reveal-on-scroll">
      <Breadcrumb items={[{ label: "Artikel", href: "/artikel" }, { label: title }]} />
    </div>

    <!-- Header Section -->
    <header class="mb-12 reveal-on-scroll">
      <!-- Pill badges for series and tags -->
      <div class="mb-6 flex flex-wrap items-center gap-2">
        {seri && <SeriBadge seri={seri} />}
        {tags && tags.map(tag => {
           let colorClass = "bg-neutral-800/60 text-neutral-300 border border-neutral-700/30";
           if (tag === "niskala" || tag === "lore" || tag === "history") {
             colorClass = "bg-[#b85a3c]/10 text-[#e68a6c] border border-[#b85a3c]/20";
           } else if (tag === "sekala" || tag === "meditation" || tag === "nature") {
             colorClass = "bg-[#1aa79b]/10 text-[#5eead4] border border-[#1aa79b]/25";
           } else if (tag === "outbound" || tag === "space-grotesk" || tag === "astronomy") {
             colorClass = "bg-[#385e54]/10 text-[#a7f3d0] border border-[#385e54]/25";
           } else if (tag === "english-hours" || tag === "mythology") {
             colorClass = "bg-[#d5c39a]/10 text-[#fde047] border border-[#d5c39a]/25";
           }
           return (
             <span class={`inline-flex items-center rounded-full px-3 py-1 text-[9px] font-mono uppercase tracking-[0.2em] font-medium shadow-sm transition-all duration-300 ${colorClass}`}>
               {tag}
             </span>
           )
        })}
        {draft && (
          <span class="inline-flex items-center rounded-full bg-[var(--color-accent)]/10 px-3 py-1 text-[9px] font-mono uppercase tracking-[0.2em] font-medium text-[var(--color-accent)] border border-[var(--color-accent)]/20 shadow-sm">
            Draf
          </span>
        )}
      </div>

      <!-- High-Contrast Editorial Heading -->
      <h1 class="font-serif text-4xl font-semibold leading-tight tracking-wide text-balance sm:text-5xl lg:text-6xl text-[var(--color-foreground)]">
        {title}
      </h1>
      
      <!-- Elegant description intro -->
      <p class="mt-6 text-lg sm:text-xl leading-relaxed text-[var(--color-muted)] text-pretty font-light italic">
        {description}
      </p>

      <div class="mt-8 flex items-center justify-between border-t border-[var(--color-border)]/20 pt-6">
        <ArticleMeta author={author} publishDate={publishDate} minutes={minutes} />
      </div>

      <!-- Double-Bezel Control Panel (Font & Text Size) -->
      <div class="mt-8 p-1 rounded-2xl bg-black/20 ring-1 ring-white/5 backdrop-blur-md shadow-inner">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 px-5 py-3 rounded-[calc(1rem+0.25rem)] bg-[var(--color-surface)] ring-1 ring-white/5">
          
          <!-- Font family selector -->
          <div class="flex items-center justify-between gap-3 md:justify-start">
            <div class="flex items-center gap-2">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-primary)]">
                <polyline points="4 7 4 4 20 4 20 7"></polyline>
                <line x1="9" y1="20" x2="15" y2="20"></line>
                <line x1="12" y1="4" x2="12" y2="20"></line>
              </svg>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)]">Gaya Huruf</span>
            </div>
            <div class="flex items-center gap-1 bg-black/20 rounded-full p-0.5 border border-white/5">
              <button 
                type="button"
                id="font-serif" 
                class="h-7 px-3.5 rounded-full flex items-center justify-center text-[10px] font-medium font-serif tracking-wider transition-all duration-300 cursor-pointer active:scale-95"
                title="Font Serif (Klasik)"
              >
                Serif
              </button>
              <button 
                type="button"
                id="font-sans" 
                class="h-7 px-3.5 rounded-full flex items-center justify-center text-[10px] font-medium font-sans tracking-wider transition-all duration-300 cursor-pointer active:scale-95"
                title="Font Sans (Modern)"
              >
                Sans
              </button>
              <button 
                type="button"
                id="font-mono" 
                class="h-7 px-3.5 rounded-full flex items-center justify-center text-[10px] font-medium font-mono tracking-wider transition-all duration-300 cursor-pointer active:scale-95"
                title="Font Mono (Kode)"
              >
                Mono
              </button>
            </div>
          </div>

          <!-- Text size changer -->
          <div class="flex items-center justify-between gap-3 md:justify-end">
            <div class="flex items-center gap-2">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-primary)]">
                <path d="M4 7V4h16v3M9 20h6M12 4v16"/>
              </svg>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)]">Ukuran Teks</span>
            </div>
            <div class="flex items-center gap-1 bg-black/20 rounded-full p-0.5 border border-white/5">
              <button 
                type="button"
                id="text-dec" 
                class="h-7 w-7 rounded-full flex items-center justify-center text-xs font-mono text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-all cursor-pointer active:scale-90"
                title="Perkecil tulisan (A-)"
              >
                A-
              </button>
              <button 
                type="button"
                id="text-normal" 
                class="h-7 px-3.5 rounded-full flex items-center justify-center text-[9px] uppercase font-mono tracking-wider font-semibold text-[var(--color-primary)] hover:text-[var(--color-foreground)] transition-all cursor-pointer active:scale-95"
                title="Ukuran normal"
              >
                Normal
              </button>
              <button 
                type="button"
                id="text-inc" 
                class="h-7 w-7 rounded-full flex items-center justify-center text-xs font-mono text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-all cursor-pointer active:scale-90"
                title="Perbesar tulisan (A+)"
              >
                A+
              </button>
            </div>
          </div>

          <!-- Export backup control group -->
          <div class="flex items-center justify-between gap-3 md:justify-end">
            <div class="flex items-center gap-2">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-primary)]">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)]">Backup</span>
            </div>
            <div class="flex items-center bg-black/20 rounded-full p-0.5 border border-white/5">
              <button 
                type="button"
                id="export-md" 
                class="h-7 px-3.5 rounded-full flex items-center justify-center text-[10px] font-medium font-mono tracking-wider text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-all duration-300 cursor-pointer active:scale-95"
                title="Unduh artikel sebagai Markdown (.md)"
                data-filename={`${entry.id}.md`}
                data-title={title}
                data-desc={description}
                data-date={publishDate}
                data-author={author}
                data-source={sourceUrl || ''}
                data-cover={cover || ''}
                data-body-base64={Buffer.from(rawBody).toString('base64')}
              >
                Unduh .MD
              </button>
            </div>
          </div>

        </div>
      </div>
    </header>

    <!-- Double-Bezel Nested Cover Image Frame -->
    {
      finalCover && (
        <div class="mb-16 rounded-[2.5rem] bg-black/15 p-2 ring-1 ring-white/10 backdrop-blur-3xl shadow-2xl reveal-on-scroll">
          <div class="overflow-hidden rounded-[calc(2.5rem-0.5rem)] border border-white/5 shadow-[inset_0_1px_2px_rgba(255,255,255,0.1)]">
            <Image
              src={finalCover}
              alt={`Ilustrasi untuk artikel ${title}`}
              loading="eager"
              widths={[480, 768, 1200]}
              sizes="(min-width: 768px) 768px, 100vw"
              class="aspect-[21/9] w-full object-cover transition-transform duration-700 hover:scale-102"
            />
          </div>
        </div>
      )
    }

    <!-- Content Split Layout -->
    <div class:list={[
      "reveal-on-scroll",
      toc.length > 0 && "lg:grid lg:grid-cols-[1fr_240px] lg:gap-14"
    ]}>
      <!-- Main Article Content Body -->
      <article class="prose min-w-0 max-w-none leading-relaxed tracking-wide text-[var(--color-foreground)]">
        <slot />
      </article>

      <!-- Sidebar Sticky TOC (machined container) -->
      {
        toc.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-28 rounded-2xl bg-black/10 p-4 ring-1 ring-white/5 border border-white/5">
              <TableOfContents toc={toc} />
            </div>
          </aside>
        )
      }
    </div>

    <!-- Article Tag Footers -->
    {
      tags.length > 0 && (
        <div class="mt-16 flex flex-wrap items-center gap-2 border-t border-[var(--color-border)]/20 pt-8 reveal-on-scroll">
          <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-muted)] mr-2">Tag Terkait:</span>
          {tags.map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      )
    }

    {
      sourceUrl && (
        <div class="mt-6 flex items-center gap-2 text-xs text-[var(--color-muted)] font-mono reveal-on-scroll">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
          </svg>
          <span>
            Originally published on{" "}
            <a href={sourceUrl} class="underline hover:text-[var(--color-foreground)] transition-colors" rel="noopener noreferrer" target="_blank">
              Quora Space
            </a>
          </span>
        </div>
      )
    }

    <!-- Premium Nested Waline Comments Section -->
    <div class="mt-16 reveal-on-scroll">
      <WalineComments path={`/artikel/${entry.id}`} />
    </div>

    <!-- Related articles -->
    <div class="reveal-on-scroll">
      <RelatedArticles entries={related} />
    </div>
  </div>

  <script>
    function initArticleControls() {
      const prose = document.querySelector('.prose');
      const decBtn = document.getElementById('text-dec');
      const normalBtn = document.getElementById('text-normal');
      const incBtn = document.getElementById('text-inc');

      const fontSerifBtn = document.getElementById('font-serif');
      const fontSansBtn = document.getElementById('font-sans');
      const fontMonoBtn = document.getElementById('font-mono');

      if (!prose) return;

      // --- TEXT SIZE ---
      const sizeClasses = ['prose-sm', 'prose-base', 'prose-lg', 'prose-xl', 'prose-2xl'];
      let currentSizeIndex = parseInt(localStorage.getItem('preferred-prose-size-index') ?? '2');
      if (isNaN(currentSizeIndex) || currentSizeIndex < 0 || currentSizeIndex >= sizeClasses.length) {
        currentSizeIndex = 2;
      }

      function updateSize() {
        sizeClasses.forEach(c => prose.classList.remove(c));
        prose.classList.add(sizeClasses[currentSizeIndex]);

        if (decBtn && incBtn) {
          decBtn.style.opacity = currentSizeIndex === 0 ? '0.3' : '1';
          decBtn.style.pointerEvents = currentSizeIndex === 0 ? 'none' : 'auto';
          
          incBtn.style.opacity = currentSizeIndex === sizeClasses.length - 1 ? '0.3' : '1';
          incBtn.style.pointerEvents = currentSizeIndex === sizeClasses.length - 1 ? 'none' : 'auto';
        }

        localStorage.setItem('preferred-prose-size-index', String(currentSizeIndex));
      }

      if (decBtn && normalBtn && incBtn) {
        decBtn.addEventListener('click', () => {
          if (currentSizeIndex > 0) {
            currentSizeIndex--;
            updateSize();
          }
        });

        incBtn.addEventListener('click', () => {
          if (currentSizeIndex < sizeClasses.length - 1) {
            currentSizeIndex++;
            updateSize();
          }
        });

        normalBtn.addEventListener('click', () => {
          currentSizeIndex = 2; // prose-lg as normal
          updateSize();
        });
      }

      updateSize();

      // --- FONT FAMILY ---
      const fontClasses = ['prose-font-serif', 'prose-font-sans', 'prose-font-mono'];
      let currentFont = localStorage.getItem('preferred-prose-font') ?? 'serif';
      if (currentFont !== 'serif' && currentFont !== 'sans' && currentFont !== 'mono') {
        currentFont = 'serif';
      }

      function updateFont() {
        fontClasses.forEach(c => prose.classList.remove(c));
        prose.classList.add(`prose-font-${currentFont}`);

        // Update button active state classes
        const fontBtns = {
          serif: fontSerifBtn,
          sans: fontSansBtn,
          mono: fontMonoBtn
        };

        Object.keys(fontBtns).forEach(key => {
          const btn = fontBtns[key];
          if (!btn) return;
          if (key === currentFont) {
            btn.classList.add('text-[var(--color-primary-foreground)]', 'bg-[var(--color-primary)]', 'shadow-inner');
            btn.classList.remove('text-[var(--color-muted)]', 'hover:bg-white/5');
          } else {
            btn.classList.remove('text-[var(--color-primary-foreground)]', 'bg-[var(--color-primary)]', 'shadow-inner');
            btn.classList.add('text-[var(--color-muted)]', 'hover:bg-white/5');
          }
        });

        localStorage.setItem('preferred-prose-font', currentFont);
      }

      if (fontSerifBtn && fontSansBtn && fontMonoBtn) {
        fontSerifBtn.addEventListener('click', () => {
          currentFont = 'serif';
          updateFont();
        });
        fontSansBtn.addEventListener('click', () => {
          currentFont = 'sans';
          updateFont();
        });
        fontMonoBtn.addEventListener('click', () => {
          currentFont = 'mono';
          updateFont();
        });
      }

      updateFont();

      // --- EXPORT ARTICLE BACKUP ---
      const exportBtn = document.getElementById('export-md');
      if (exportBtn) {
        exportBtn.addEventListener('click', () => {
          const filename = exportBtn.getAttribute('data-filename');
          const title = exportBtn.getAttribute('data-title');
          const desc = exportBtn.getAttribute('data-desc');
          const date = exportBtn.getAttribute('data-date');
          const author = exportBtn.getAttribute('data-author');
          const source = exportBtn.getAttribute('data-source');
          const cover = exportBtn.getAttribute('data-cover');
          const bodyBase64 = exportBtn.getAttribute('data-body-base64');
          
          try {
            // Decode raw content dari Base64 secara aman dengan dukungan UTF-8
            const rawBody = decodeURIComponent(escape(window.atob(bodyBase64)));
            
            const frontmatter = `---
title: "${title.replace(/"/g, '\\"')}"
description: "${desc.replace(/"/g, '\\"')}"
publishDate: "${date}"
author: "${author}"
tags: ["quora-backup"]
${source ? `sourceUrl: "${source}"\n` : ''}${cover ? `cover: "${cover}"\n` : ''}---

`;
            const fullContent = frontmatter + rawBody;
            const blob = new Blob([fullContent], { type: 'text/markdown;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
          } catch (e) {
            console.error('Gagal mengekspor artikel:', e);
            alert('Gagal mengekspor artikel.');
          }
        });
      }
    }

    // Load initial controls state
    initArticleControls();
    
    // Support page transitions
    document.addEventListener('astro:after-swap', initArticleControls);
  </script>
</BaseLayout>
