---
import { seriLabel } from "@/lib/utils"
interface Props {
  seri: string
  link?: boolean
}
const { seri, link = true } = Astro.props
const label = seriLabel(seri)
const classes =
  "inline-flex items-center gap-1 rounded-full bg-[var(--color-primary)]/15 px-2.5 py-0.5 text-xs font-semibold text-[var(--color-primary)] transition-colors hover:bg-[var(--color-primary)]/25"
---

{
  link ? (
    <a href={`/seri/${seri}`} class={classes}>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z" />
      </svg>
      {label}
    </a>
  ) : (
    <span class={classes}>{label}</span>
  )
}
