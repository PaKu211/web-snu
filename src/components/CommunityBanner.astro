---
import Button from "@/components/Button.astro"
import { QUORA_URL } from "@/config"

interface Props {
  quoraUrl?: string
  class?: string
}

const {
  quoraUrl = QUORA_URL,
  class: className = ""
} = Astro.props
---

<div
  class:list={[
    "relative overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-gradient-to-br from-[var(--color-surface)] to-[var(--color-surface-2)] p-6 shadow-sm",
    className
  ]}
>
  <!-- Background blur pattern matching the design system -->
  <div class="absolute -right-10 -bottom-10 h-32 w-32 rounded-full bg-[var(--color-primary)]/10 blur-3xl pointer-events-none"></div>
  
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5 relative z-10">
    <div class="space-y-1.5 max-w-md">
      <div class="flex items-center gap-2 text-[var(--color-primary)]">
        <!-- Chat/Community icon -->
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
        <span class="font-serif text-sm font-bold uppercase tracking-wider">Gabung Komunitas</span>
      </div>
      <h3 id="community-heading" class="font-serif text-lg font-semibold text-[var(--color-foreground)] leading-tight">
        Sekala Niskala Universe (Quora Space)
      </h3>
      <p class="text-xs sm:text-sm text-[var(--color-muted)] leading-relaxed">
        Tempat kami berkumpul, berbagi tulisan, dan berdiskusi secara aktif. Kami juga tersedia di Discord untuk kegiatan seperti Meditasi Bareng, Nobar, dan Ngobrol Satu Jam Bersama.
      </p>
    </div>
    
    <div class="flex-shrink-0">
      <Button
        href={quoraUrl}
        target="_blank"
        rel="noopener noreferrer"
        variant="primary"
        class="font-semibold text-xs tracking-wide"
      >
        Kunjungi Quora Space
      </Button>
    </div>
  </div>
</div>
