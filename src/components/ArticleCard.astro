---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import { formatDate, readingTime } from "@/lib/utils"
import SeriBadge from "@/components/SeriBadge.astro"

interface Props {
  entry: CollectionEntry<"artikel">
  body?: string
  featured?: boolean
}

const { entry, body = "", featured = false } = Astro.props
const { title, description, author, publishDate, tags, seri, cover, draft } = entry.data
const minutes = readingTime(body || description)
const href = `/artikel/${entry.id}`
---

<article
  class:list={[
    "p-1.5 rounded-[1.75rem] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[0_12px_24px_-12px_rgba(0,0,0,0.3)] transition-premium hover:shadow-[0_20px_32px_-10px_rgba(0,0,0,0.45)] hover:border-[var(--color-primary)]/30 hover:-translate-y-0.5 group flex flex-col",
    featured && "md:rounded-[2.25rem] md:flex-row md:items-stretch",
  ]}
>
  {
    cover && (
      <a
        href={href}
        class:list={[
          "relative block overflow-hidden rounded-[1.375rem] bg-[var(--color-surface-2)] border border-[var(--color-border)]/50",
          featured ? "md:w-1/2 md:rounded-[1.8rem]" : "aspect-[16/9]",
        ]}
        aria-hidden="true"
        tabindex="-1"
      >
        <Image
          src={cover}
          alt=""
          widths={[400, 800]}
          sizes="(min-width: 768px) 50vw, 100vw"
          class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-103"
        />
      </a>
    )
  }

  <div 
    class:list={[
      "flex flex-1 flex-col gap-4 p-5 sm:p-6 rounded-[1.375rem] bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/40 mt-2",
      cover && !featured && "mt-3",
      featured && "md:mt-0 md:ml-3 md:justify-center md:p-8 md:rounded-[1.8rem]",
    ]}
  >
    <div class="flex flex-wrap items-center gap-2">
      {seri && <SeriBadge seri={seri} />}
      {draft && (
        <span class="inline-flex items-center rounded-full bg-[var(--color-accent)]/15 px-2.5 py-0.5 text-[9px] font-mono uppercase tracking-[0.15em] text-[var(--color-accent)] border border-[var(--color-accent)]/20">
          Draf
        </span>
      )}
      {featured && !seri && (
        <span class="inline-flex items-center rounded-full bg-[var(--color-primary)]/15 px-2.5 py-0.5 text-[9px] font-mono uppercase tracking-[0.15em] text-[var(--color-primary)] border border-[var(--color-primary)]/20">
          Disematkan
        </span>
      )}
    </div>

    <div class="space-y-2.5">
      <h2 class:list={[
        "font-serif font-medium leading-snug tracking-tight text-[var(--color-foreground)] transition-colors group-hover:text-[var(--color-primary)]", 
        featured ? "text-2xl sm:text-3xl" : "text-xl"
      ]}>
        <a href={href}>
          {title}
        </a>
      </h2>

      <p class:list={[
        "text-sm leading-relaxed text-[var(--color-muted)]", 
        featured ? "text-base max-w-[60ch]" : "line-clamp-2"
      ]}>
        {description}
      </p>
    </div>

    <div class="mt-auto pt-4 border-t border-[var(--color-border)]/30 flex items-center justify-between">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[10px] font-mono uppercase tracking-[0.15em] text-[var(--color-muted)]">
        <span class="font-medium text-[var(--color-foreground)]">{author}</span>
        <span aria-hidden="true" class="text-[var(--color-border)]">&middot;</span>
        <time datetime={publishDate.toISOString()}>{formatDate(publishDate)}</time>
        <span aria-hidden="true" class="text-[var(--color-border)]">&middot;</span>
        <span>{minutes} m baca</span>
      </div>
      
      <a href={href} class="inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-primary)] group/link" aria-label={`Baca selengkapnya tentang ${title}`}>
        Baca 
        <span class="inline-block transition-transform duration-300 group-hover/link:translate-x-1">&rarr;</span>
      </a>
    </div>
  </div>
</article>
