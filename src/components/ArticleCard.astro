---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import { formatDate } from "@/lib/utils"
import SeriBadge from "@/components/SeriBadge.astro"
import coverTemple from "@/assets/cover_temple.jpg"
import coverMeditation from "@/assets/cover_meditation.jpg"

interface Props {
  entry: CollectionEntry<"artikel">
  featured?: boolean
  loading?: "lazy" | "eager"
}

const { entry, featured = false, loading = "lazy" } = Astro.props
const { title, description, author, publishDate, tags, seri, cover, draft } = entry.data

const href = `/artikel/${entry.id}`

const fallbackCovers = [
  coverTemple,
  coverMeditation,
]
const finalCover = cover || fallbackCovers[entry.id.charCodeAt(0) % fallbackCovers.length]
---

<article
  class:list={[
    "p-1.5 rounded-[1.75rem] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[0_12px_24px_-12px_rgba(0,0,0,0.3)] transition-premium hover:shadow-[0_20px_32px_-10px_rgba(0,0,0,0.45)] hover:border-[var(--color-primary)]/30 hover:-translate-y-0.5 group flex flex-col",
    featured && "md:rounded-[2.25rem] md:flex-row md:items-stretch",
  ]}
>
  {
    finalCover && (
      <a
        href={href}
        class:list={[
          "relative block overflow-hidden rounded-[1.375rem] bg-[var(--color-surface-2)] border border-[var(--color-border)]/50",
          featured ? "md:w-1/2 md:rounded-[1.8rem]" : "aspect-[16/9]",
        ]}
        aria-label={`Gambar sampul: ${title}`}
      >
        <Image
          src={finalCover}
          alt=""
          loading={loading}
          widths={[400, 800]}
          sizes="(min-width: 768px) 50vw, 100vw"
          class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-103"
        />
      </a>
    )
  }

  <div 
    class:list={[
      "flex flex-1 flex-col gap-4 p-5 sm:p-6 rounded-[1.375rem] bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/40 mt-2",
      cover && !featured && "mt-3",
      featured && "md:mt-0 md:ml-3 md:justify-center md:p-8 md:rounded-[1.8rem]",
    ]}
  >
    <div class="flex flex-wrap items-center gap-1.5">
      {seri && <SeriBadge seri={seri} />}
      {tags && tags.map(tag => {
         let colorClass = "bg-neutral-800 text-neutral-300";
         if (tag === "niskala" || tag === "lore" || tag === "history") colorClass = "bg-[#b85a3c]/15 text-[#e68a6c] border border-[#b85a3c]/25";
         else if (tag === "sekala" || tag === "meditation" || tag === "nature") colorClass = "bg-[#1aa79b]/15 text-[#1aa79b] border border-[#1aa79b]/25";
         else if (tag === "outbound" || tag === "space-grotesk" || tag === "astronomy") colorClass = "bg-[#385e54]/15 text-[#82b4a5] border border-[#385e54]/25";
         else if (tag === "english-hours" || tag === "mythology") colorClass = "bg-[#d5c39a]/15 text-[#d5c39a] border border-[#d5c39a]/25";
         return (
           <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-[9px] font-mono uppercase tracking-[0.1em] ${colorClass}`}>
             {tag}
           </span>
         )
      })}
      {draft && (
        <span class="inline-flex items-center rounded-full bg-[var(--color-accent)]/15 px-2.5 py-0.5 text-[9px] font-mono uppercase tracking-[0.1em] text-[var(--color-accent)] border border-[var(--color-accent)]/20">
          Draf
        </span>
      )}
      {featured && !seri && (
        <span class="inline-flex items-center rounded-full bg-[var(--color-primary)]/15 px-2.5 py-0.5 text-[9px] font-mono uppercase tracking-[0.1em] text-[var(--color-primary)] border border-[var(--color-primary)]/20">
          Disematkan
        </span>
      )}
    </div>

    <div class="space-y-2.5">
      <h2 class:list={[
        "font-serif font-medium leading-snug tracking-wide text-[var(--color-foreground)] transition-colors group-hover:text-[var(--color-primary)]", 
        featured ? "text-2xl sm:text-3.5xl" : "text-xl"
      ]}>
        <a href={href}>
          {title}
        </a>
      </h2>

      <p class:list={[
        "text-sm leading-relaxed text-[var(--color-muted)]", 
        featured ? "text-base max-w-[60ch]" : "line-clamp-2"
      ]}>
        {description}
      </p>
    </div>

    <div class="mt-auto pt-4 border-t border-[var(--color-border)]/30 flex flex-col gap-3">
      <div class="flex flex-col text-[10px] font-mono uppercase tracking-[0.12em] text-[var(--color-muted)] gap-1">
        <div><span class="text-[var(--color-foreground)]/45">Author:</span> {author}</div>
        <div><span class="text-[var(--color-foreground)]/45">Date:</span> {formatDate(publishDate)}</div>
      </div>
      <div class="flex items-center justify-between pt-2 border-t border-[var(--color-border)]/10">
        <span class="text-[9px] font-mono uppercase tracking-[0.15em] text-[var(--color-primary)] font-semibold">Morning Mist</span>
        <a href={href} class="inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-accent)] group/link" aria-label={`Baca selengkapnya tentang ${title}`}>
          Baca 
          <span class="inline-block transition-transform duration-300 group-hover/link:translate-x-1">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</article>
