---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import { formatDate, readingTime } from "@/lib/utils"
import SeriBadge from "@/components/SeriBadge.astro"
import TagBadge from "@/components/TagBadge.astro"

interface Props {
  entry: CollectionEntry<"artikel">
  body?: string
  featured?: boolean
}

const { entry, body = "", featured = false } = Astro.props
const { title, description, author, publishDate, tags, seri, cover, draft } = entry.data
const minutes = readingTime(body || description)
const href = `/artikel/${entry.id}`
---

<article
  class:list={[
    "group flex flex-col overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] transition-colors hover:border-[var(--color-primary)]/60",
    featured && "md:flex-row",
  ]}
>
  {
    cover && (
      <a
        href={href}
        class:list={[
          "relative block overflow-hidden bg-[var(--color-surface-2)]",
          featured ? "md:w-1/2" : "",
        ]}
        aria-hidden="true"
        tabindex="-1"
      >
        <Image
          src={cover}
          alt=""
          widths={[400, 800]}
          sizes="(min-width: 768px) 50vw, 100vw"
          class:list={[
            "h-full w-full object-cover transition-transform duration-500 group-hover:scale-105",
            featured ? "aspect-[4/3] md:aspect-auto" : "aspect-[16/9]",
          ]}
        />
      </a>
    )
  }

  <div class:list={["flex flex-1 flex-col gap-3 p-5", featured && "md:justify-center md:p-8"]}>
    <div class="flex flex-wrap items-center gap-2">
      {seri && <SeriBadge seri={seri} />}
      {draft && (
        <span class="inline-flex items-center rounded-full bg-[var(--color-accent)]/20 px-2.5 py-0.5 text-xs font-semibold text-[var(--color-accent)]">
          Draf
        </span>
      )}
      {featured && !seri && (
        <span class="inline-flex items-center rounded-full bg-[var(--color-primary)]/15 px-2.5 py-0.5 text-xs font-semibold text-[var(--color-primary)]">
          Disematkan
        </span>
      )}
    </div>

    <h2 class:list={["font-serif font-semibold leading-snug", featured ? "text-2xl" : "text-lg"]}>
      <a href={href} class="transition-colors hover:text-[var(--color-primary)]">
        {title}
      </a>
    </h2>

    <p class:list={["text-sm leading-relaxed text-[var(--color-muted)]", featured ? "" : "line-clamp-2"]}>
      {description}
    </p>

    <div class="mt-auto flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-[var(--color-muted)]">
      <span class="font-medium text-[var(--color-foreground)]">{author}</span>
      <span aria-hidden="true">&middot;</span>
      <time datetime={publishDate.toISOString()}>{formatDate(publishDate)}</time>
      <span aria-hidden="true">&middot;</span>
      <span>{minutes} menit</span>
    </div>

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.slice(0, featured ? 4 : 2).map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      )
    }
  </div>
</article>
