---
import type { CollectionEntry } from "astro:content"
import { formatDate } from "@/lib/utils"

interface Props {
  entries: CollectionEntry<"artikel">[]
}
const { entries } = Astro.props
---

{
  entries.length > 0 && (
    <section class="mt-16 border-t border-[var(--color-border)] pt-10" aria-labelledby="related-heading">
      <h2 id="related-heading" class="font-serif text-xl font-semibold">
        Bacaan Terkait
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {entries.map((entry) => (
          <a
            href={`/artikel/${entry.id}`}
            class="group flex flex-col gap-2 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface)] p-4 transition-colors hover:border-[var(--color-primary)]/60"
          >
            <h3 class="font-serif text-base font-semibold leading-snug transition-colors group-hover:text-[var(--color-primary)]">
              {entry.data.title}
            </h3>
            <time
              datetime={entry.data.publishDate.toISOString()}
              class="mt-auto text-xs text-[var(--color-muted)]"
            >
              {formatDate(entry.data.publishDate)}
            </time>
          </a>
        ))}
      </div>
    </section>
  )
}
