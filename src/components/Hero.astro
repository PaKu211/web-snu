---
import { SITE } from "@/config"
import Button from "@/components/Button.astro"

interface Props {
  eyebrow?: string
  title?: string
  subtitle?: string
}

const {
  eyebrow = "Sekala · Niskala",
  title = "Sekala Niskala Universe",
  subtitle = "Di batas nyata dan tak kasat. Menjelajahi jati diri dan kesadaran melalui kebajikan leluhur serta alam semesta.",
} = Astro.props
---

<section class="relative min-h-[75vh] flex items-center justify-center overflow-hidden border-b border-[var(--color-border)] py-24 sm:py-32">
  <!-- Mystical Forest Mist Background Image -->
  <div 
    class="absolute inset-0 z-0 bg-[url('/hero_bg.jpg')] bg-cover bg-center bg-no-repeat opacity-45"
    aria-hidden="true"
  ></div>
  
  <!-- Smooth Cinematic Gradient Fading Overlay -->
  <div 
    class="absolute inset-0 z-0 bg-gradient-to-b from-transparent via-[var(--color-background)]/70 to-[var(--color-background)]"
    aria-hidden="true"
  ></div>

  <!-- Drifting Ambient glows for volumetric volumetric fog effect -->
  <div class="mesh-glow-1 pointer-events-none absolute top-1/4 left-1/4 h-[400px] w-[400px] rounded-full bg-[var(--color-accent)]/10 blur-[100px]" aria-hidden="true"></div>
  <div class="mesh-glow-2 pointer-events-none absolute bottom-1/4 right-1/4 h-[500px] w-[500px] rounded-full bg-[var(--color-primary)]/8 blur-[120px]" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 text-center w-full">
    <div class="max-w-4xl mx-auto flex flex-col items-center">
      
      <!-- Eyebrow text matching header style -->
      <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)]/80 backdrop-blur-sm px-4 py-1.5 text-[10px] font-mono uppercase tracking-[0.25em] text-[var(--color-primary)] shadow-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] animate-pulse" aria-hidden="true"></span>
        {eyebrow}
      </span>
      
      <!-- Cormorant Upright Gold Editorial Title -->
      <h1
        class="mt-8 font-serif text-5xl font-medium leading-[1.05] tracking-wide text-pretty sm:text-6xl md:text-7.5xl text-[var(--color-foreground)] max-w-4xl"
        style="text-shadow: 0 4px 12px rgba(0,0,0,0.6);"
      >
        {title}
      </h1>
      
      <!-- Grotesque Lede Paragraph -->
      <p 
        class="mt-6 max-w-[56ch] text-base sm:text-lg leading-relaxed text-[var(--color-muted)] text-pretty"
        style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);"
      >
        {subtitle}
      </p>
      
      <!-- Centered Premium Accent CTA buttons matching target layout -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <Button 
          href="/artikel" 
          variant="accent" 
          size="lg" 
          class="font-semibold uppercase tracking-[0.1em] px-8 text-xs h-12 shadow-[0_8px_24px_rgba(26,167,155,0.25)] border border-[var(--color-accent)]/20"
          hasArrow
        >
          Mulai Membaca
        </Button>
        <Button 
          href="https://sekalaniskalauniverse.quora.com/" 
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary" 
          size="lg" 
          class="font-semibold uppercase tracking-[0.1em] px-8 text-xs h-12 border border-[var(--color-border)] text-[var(--color-foreground)] shadow-[0_4px_12px_rgba(0,0,0,0.15)]"
        >
          Quora Space
        </Button>
      </div>
    </div>
  </div>
</section>
