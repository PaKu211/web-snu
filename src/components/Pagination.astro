---
interface Props {
  currentPage: number
  lastPage: number
  prevUrl?: string
  nextUrl?: string
  baseUrl: string
}
const { currentPage, lastPage, prevUrl, nextUrl, baseUrl } = Astro.props

function pageUrl(n: number) {
  return n === 1 ? baseUrl : `${baseUrl}/page/${n}`
}

const range = (start: number, end: number) => {
  let length = end - start + 1;
  return Array.from({ length }, (_, idx) => idx + start);
};

const totalNumbers = 5; 
const siblingCount = 1;

let pages: (number | string)[] = [];
if (lastPage <= totalNumbers + 2) {
  pages = range(1, lastPage);
} else {
  const leftSiblingIndex = Math.max(currentPage - siblingCount, 1);
  const rightSiblingIndex = Math.min(currentPage + siblingCount, lastPage);

  const shouldShowLeftDots = leftSiblingIndex > 2;
  const shouldShowRightDots = rightSiblingIndex < lastPage - 2;

  if (!shouldShowLeftDots && shouldShowRightDots) {
    let leftItemCount = 3 + 2 * siblingCount;
    let leftRange = range(1, leftItemCount);
    pages = [...leftRange, '...', lastPage];
  } else if (shouldShowLeftDots && !shouldShowRightDots) {
    let rightItemCount = 3 + 2 * siblingCount;
    let rightRange = range(lastPage - rightItemCount + 1, lastPage);
    pages = [1, '...', ...rightRange];
  } else if (shouldShowLeftDots && shouldShowRightDots) {
    let middleRange = range(leftSiblingIndex, rightSiblingIndex);
    pages = [1, '...', ...middleRange, '...', lastPage];
  } else {
    pages = range(1, lastPage);
  }
}

const base =
  "inline-flex h-9 min-w-9 items-center justify-center rounded-md border border-[var(--color-border)] px-3 text-sm font-medium transition-colors"
const enabled = "bg-[var(--color-surface)] text-[var(--color-foreground)] hover:bg-[var(--color-surface-2)]"
const disabled = "cursor-not-allowed opacity-40 bg-[var(--color-surface)] text-[var(--color-muted)]"
---

{
  lastPage > 1 && (
    <nav aria-label="Paginasi" class="mt-12 flex items-center justify-center gap-2">
      {prevUrl ? (
        <a href={prevUrl} rel="prev" class:list={[base, enabled]}>
          &larr; Sebelumnya
        </a>
      ) : (
        <span class:list={[base, disabled]} aria-disabled="true">
          &larr; Sebelumnya
        </span>
      )}

      <div class="hidden items-center gap-1 sm:flex">
        {pages.map((n) => {
          if (n === '...') {
            return (
              <span class:list={[base, "text-[var(--color-muted)] border-none select-none px-1.5"]}>
                ...
              </span>
            )
          }
          return (
            <a
              href={pageUrl(n as number)}
              aria-current={n === currentPage ? "page" : undefined}
              class:list={[
                base,
                n === currentPage
                  ? "bg-[var(--color-primary)] text-[var(--color-primary-foreground)] border-[var(--color-primary)]"
                  : enabled,
              ]}
            >
              {n}
            </a>
          )
        })}
      </div>

      <span class="text-sm text-[var(--color-muted)] sm:hidden">
        {currentPage} / {lastPage}
      </span>

      {nextUrl ? (
        <a href={nextUrl} rel="next" class:list={[base, enabled]}>
          Berikutnya &rarr;
        </a>
      ) : (
        <span class:list={[base, disabled]} aria-disabled="true">
          Berikutnya &rarr;
        </span>
      )}
    </nav>
  )
}
