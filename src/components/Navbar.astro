---
import { NAV_LINKS, SITE } from "@/config"
import ThemeToggle from "@/components/ThemeToggle.tsx"

const path = Astro.url.pathname
function isActive(href: string) {
  if (href === "/") return path === "/"
  return path === href || path.startsWith(`${href}/`)
}
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-background)]/85 backdrop-blur"
>
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between gap-4 px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 group" aria-label={`${SITE.name} — beranda`}>
      <span
        class="flex h-9 w-9 items-center justify-center rounded-md bg-[var(--color-primary)] font-serif text-base font-semibold text-[var(--color-primary-foreground)]"
        aria-hidden="true">SN</span
      >
      <span class="flex flex-col leading-none">
        <span class="font-serif text-base font-semibold tracking-tight">Sekala Niskala</span>
        <span class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-muted)]">Portal</span>
      </span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-md px-3 py-2 text-sm font-medium transition-colors",
              isActive(link.href)
                ? "bg-[var(--color-surface-2)] text-[var(--color-foreground)]"
                : "text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)]",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <a
        href="/cari"
        aria-label="Cari artikel"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-foreground)] transition-colors hover:bg-[var(--color-surface-2)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-ring)]"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>
      <ThemeToggle client:load />
      <button
        type="button"
        id="mobile-menu-button"
        aria-label="Buka menu"
        aria-expanded="false"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-foreground)] transition-colors hover:bg-[var(--color-surface-2)] md:hidden"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-[var(--color-border)] px-4 py-3 md:hidden">
    <div class="flex flex-col gap-1">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-md px-3 py-2 text-sm font-medium transition-colors",
              isActive(link.href)
                ? "bg-[var(--color-surface-2)] text-[var(--color-foreground)]"
                : "text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)]",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button")
  const menu = document.getElementById("mobile-menu")
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false
    btn.setAttribute("aria-expanded", String(open))
  })
</script>
