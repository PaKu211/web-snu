---
import { NAV_LINKS, SITE } from "@/config"
import ThemeToggle from "@/components/ThemeToggle.tsx"

const path = Astro.url.pathname
function isActive(href: string) {
  if (href === "/") return path === "/"
  return path === href || path.startsWith(`${href}/`)
}
---

<header
  class="sticky top-6 z-50 mx-auto max-w-5xl px-4 sm:px-6 w-full"
>
  <!-- Double-bezel floating navbar wrapper -->
  <div class="p-1 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)]/80 backdrop-blur-md shadow-[0_8px_20px_-6px_rgba(0,0,0,0.3)] transition-all duration-300">
    <div class="flex h-14 items-center justify-between gap-4 px-4 rounded-full bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/20">
      
      <a href="/" class="flex items-center gap-2.5 group" aria-label={`${SITE.name} — beranda`}>
        <span
          class="flex h-8.5 w-8.5 items-center justify-center rounded-full bg-[var(--color-primary)] font-serif text-[13px] font-semibold text-[var(--color-primary-foreground)] transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-105"
          aria-hidden="true">SN</span>
        <span class="flex flex-col leading-none">
          <span class="font-serif text-sm font-semibold tracking-tight text-[var(--color-foreground)] transition-colors group-hover:text-[var(--color-primary)]">Sekala Niskala</span>
          <span class="text-[9px] uppercase tracking-[0.2em] text-[var(--color-muted)] font-mono">Portal</span>
        </span>
      </a>

      <div class="hidden items-center gap-1 md:flex">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class:list={[
                "rounded-full px-4 py-2 text-xs font-medium transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]",
                isActive(link.href)
                  ? "bg-[var(--color-surface-2)] text-[var(--color-foreground)] border border-[var(--color-border)]/40 shadow-sm"
                  : "text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface-2)]/50",
              ]}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-2">
        <a
          href="/cari"
          aria-label="Cari artikel"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface-2)]/50 text-[var(--color-foreground)] transition-colors hover:bg-[var(--color-surface-2)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-ring)]"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </a>
        <ThemeToggle client:load />
        <button
          type="button"
          id="mobile-menu-button"
          aria-label="Buka menu"
          aria-expanded="false"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface-2)]/50 text-[var(--color-foreground)] transition-colors hover:bg-[var(--color-surface-2)] md:hidden"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="7" x2="20" y2="7"></line>
            <line x1="4" y1="12" x2="20" y2="12"></line>
            <line x1="4" y1="17" x2="20" y2="17"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden mt-2 mx-2 p-1 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/95 backdrop-blur-md md:hidden shadow-lg">
    <div class="flex flex-col gap-1 p-2 rounded-xl bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/20">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-lg px-4 py-2 text-xs font-medium transition-colors",
              isActive(link.href)
                ? "bg-[var(--color-surface-2)] text-[var(--color-foreground)] border border-[var(--color-border)]/30"
                : "text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface-2)]/50",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button")
  const menu = document.getElementById("mobile-menu")
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false
    btn.setAttribute("aria-expanded", String(open))
  })
</script>
