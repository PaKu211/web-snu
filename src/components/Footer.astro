---
import { NAV_LINKS, SITE, QUORA_URL } from "@/config"
import { Image } from "astro:assets"
import logoImg from "@/assets/snlogo.png"
const year = new Date().getFullYear()
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <div class="flex items-center gap-3">
          <!-- Official mandala logo image -->
          <div class="relative flex items-center justify-center h-8 w-8 rounded-full bg-black border border-[var(--color-primary)]/20 overflow-hidden shadow-[0_2px_8px_rgba(0,0,0,0.4)]">
            <Image src={logoImg} alt="Logo Sekala Niskala" class="h-full w-full object-cover" width={32} height={32} />
          </div>
          <span class="font-serif text-base font-semibold">Sekala Niskala</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
          {SITE.description}
        </p>
      </div>

      <nav aria-label="Tautan footer" class="flex flex-col gap-2">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
          Jelajah
        </h2>
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <nav aria-label="Tautan eksternal" class="flex flex-col gap-2">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
          Hubung & Dukung
        </h2>
        <a href="mailto:sekalaniskalauniverse@gmail.com" class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]">Email Kami</a>
        <a href="https://sociabuzz.com/sekalaniskala/tribe" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]">Donasi SociaBuzz</a>
        <a href="/rss.xml" class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]">RSS Feed</a>
      </nav>

      <nav aria-label="Media Sosial" class="flex flex-col gap-2">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
          Media Sosial
        </h2>
        <a href={QUORA_URL} target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]">Quora Space</a>
        <a href="https://instagram.com/sekalaniskala" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]">Instagram</a>
        <a href="https://threads.net/@sekalaniskala_u" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]">Threads</a>
      </nav>
    </div>

    <div
      class="mt-10 flex flex-col items-center justify-between gap-2 border-t border-[var(--color-border)] pt-6 text-xs text-[var(--color-muted)] sm:flex-row w-full text-center sm:text-left"
    >
      <p>&copy; {year} Komunitas Sekala Niskala. Yang tampak dan yang tak tampak.</p>
    </div>
  </div>
</footer>
