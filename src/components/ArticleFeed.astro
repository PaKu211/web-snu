---
import type { CollectionEntry } from "astro:content"
import Breadcrumb from "@/components/Breadcrumb.astro"
import ArticleCard from "@/components/ArticleCard.astro"
import Pagination from "@/components/Pagination.astro"
import EmptyState from "@/components/EmptyState.astro"

interface Props {
  entries: CollectionEntry<"artikel">[]
  bodies: Record<string, string>
  tags: { tag: string; count: number }[]
  seri: { seri: string; count: number }[]
  currentPage: number
  lastPage: number
  prevUrl?: string
  nextUrl?: string
}
const { entries, bodies, tags, seri, currentPage, lastPage, prevUrl, nextUrl } = Astro.props
---

<div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
  <Breadcrumb items={[{ label: "Artikel" }]} />

  <header class="mb-8">
    <h1 class="font-serif text-3xl font-semibold sm:text-4xl">Artikel</h1>
    <p class="mt-2 text-[var(--color-muted)]">
      Semua tulisan komunitas — refleksi, perjalanan, dan ruang di antaranya.
    </p>
  </header>

  {
    (tags.length > 0 || seri.length > 0) && (
      <div class="p-1 rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-sm mb-10">
        <div class="flex flex-col gap-4 p-4 rounded-[1.15rem] bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/40">
          {tags.length > 0 && (
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-[9px] font-mono uppercase tracking-[0.2em] text-[var(--color-muted)] mr-2">
                Tag
              </span>
              {tags.map(({ tag, count }) => (
                <a
                  href={`/tag/${tag}`}
                  class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-2)]/60 px-3 py-1.5 text-[10px] font-mono uppercase tracking-[0.1em] text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)] hover:border-[var(--color-primary)]/40"
                >
                  #{tag}
                  <span class="text-[9px] font-sans font-semibold bg-[var(--color-surface)] border border-[var(--color-border)] px-1.5 py-0.5 rounded-full text-[var(--color-muted)] leading-none">{count}</span>
                </a>
              ))}
            </div>
          )}
          {seri.length > 0 && (
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-[9px] font-mono uppercase tracking-[0.2em] text-[var(--color-muted)] mr-2">
                Seri
              </span>
              {seri.map(({ seri: s, count }) => (
                <a
                  href={`/seri/${s}`}
                  class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/10 px-3 py-1.5 text-[10px] font-mono uppercase tracking-[0.1em] text-[var(--color-primary)] transition-colors hover:bg-[var(--color-primary)]/20"
                >
                  {s}
                  <span class="text-[9px] font-sans font-semibold bg-[var(--color-surface)] border border-[var(--color-primary)]/20 px-1.5 py-0.5 rounded-full text-[var(--color-primary)] leading-none">{count}</span>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    )
  }

  {
    entries.length > 0 ? (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {entries.map((entry) => (
          <ArticleCard entry={entry} body={bodies[entry.id]} />
        ))}
      </div>
    ) : (
      <EmptyState title="Belum ada tulisan" description="Artikel akan muncul di sini setelah dipublikasikan." />
    )
  }

  <Pagination
    currentPage={currentPage}
    lastPage={lastPage}
    prevUrl={prevUrl}
    nextUrl={nextUrl}
    baseUrl="/artikel"
  />
</div>
