---
import { getCollection } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Hero from "@/components/Hero.astro"
import ArticleCard from "@/components/ArticleCard.astro"
import EmptyState from "@/components/EmptyState.astro"
import TagBadge from "@/components/TagBadge.astro"
import Button from "@/components/Button.astro"
import EventCard from "@/components/EventCard.astro"
import DiscordBanner from "@/components/DiscordBanner.astro"
import { collectTags, sortArtikel } from "@/lib/utils"

const all = sortArtikel(await getCollection("artikel"))
const featured = all.find((a) => a.data.featured) ?? all[0]
const rest = all.filter((a) => a.id !== featured?.id).slice(0, 6)
const tags = collectTags(all).slice(0, 8)

// Retrieve upcoming events
const allEvents = await getCollection("events", ({ data }) => import.meta.env.DEV || !data.draft)
const now = new Date()
const upcomingEvents = allEvents
  .filter((e) => {
    const end = e.data.endDate ?? new Date(e.data.startDate.getTime() + 24 * 60 * 60 * 1000)
    return end >= now
  })
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf())
  .slice(0, 2)
---

<BaseLayout>
  <Hero />

  <div class="mx-auto max-w-5xl px-4 py-14 sm:px-6">
    {
      featured && (
        <section class="mb-14" aria-labelledby="featured-heading">
          <div class="mb-5 flex items-baseline justify-between">
            <h2 id="featured-heading" class="font-serif text-2xl font-semibold">
              Disematkan
            </h2>
          </div>
          <ArticleCard entry={featured}  featured loading="eager" />
        </section>
      )
    }

    {
      tags.length > 0 && (
        <section class="mb-14" aria-labelledby="tags-heading">
          <h2 id="tags-heading" class="mb-5 font-serif text-2xl font-semibold">
            Telusuri Tema
          </h2>
          <div class="flex flex-wrap gap-2">
            {tags.map(({ tag, count }) => (
              <a
                href={`/tag/${tag}`}
                class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-2)]/60 px-3.5 py-1.5 text-[10px] font-mono uppercase tracking-[0.1em] text-[var(--color-muted)] transition-all duration-300 hover:bg-[var(--color-surface-2)] hover:text-[var(--color-foreground)] hover:border-[var(--color-primary)]/40"
              >
                #{tag}
                <span class="text-[9px] font-sans font-semibold bg-[var(--color-surface)] border border-[var(--color-border)] px-1.5 py-0.5 rounded-full text-[var(--color-muted)] leading-none">{count}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      upcomingEvents.length > 0 && (
        <section class="mb-14" aria-labelledby="upcoming-events-heading">
          <div class="mb-5 flex items-baseline justify-between border-b border-[var(--color-border)]/30 pb-2">
            <h2 id="upcoming-events-heading" class="font-serif text-2xl font-semibold">
              Kegiatan Mendatang
            </h2>
            <Button href="/events" variant="ghost" size="sm" class="text-[var(--color-primary)] hover:text-[var(--color-primary)]/80 text-xs">
              Lihat semua &rarr;
            </Button>
          </div>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            {upcomingEvents.map((event) => (
              <EventCard event={event} />
            ))}
          </div>
        </section>
      )
    }

    <section aria-labelledby="latest-heading">
      <div class="mb-5 flex items-baseline justify-between">
        <h2 id="latest-heading" class="font-serif text-2xl font-semibold">Tulisan Terbaru</h2>
        <Button href="/artikel" variant="ghost" size="sm" class="text-[var(--color-primary)] hover:text-[var(--color-primary)]/80">
          Lihat semua &rarr;
        </Button>
      </div>
      {
        rest.length > 0 ? (
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {rest.map((entry) => (
              <ArticleCard entry={entry} />
            ))}
            
            {/* Custom Seri Badge Bento Card matching target layout */}
            <div class="p-1.5 rounded-[1.75rem] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[0_12px_24px_-12px_rgba(0,0,0,0.3)] flex flex-col justify-between group">
              <a href="/seri/wpm-saga" class="flex flex-1 flex-col justify-center items-center p-6 rounded-[1.375rem] bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/40 text-center gap-4 min-h-[320px] hover:no-underline">
                <span class="text-[9px] font-mono uppercase tracking-[0.2em] text-[var(--color-muted)]">Seri Pilihan</span>
                <div class="h-28 w-28 rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-surface-2)]/50 flex items-center justify-center relative">
                  <!-- Gold Crest Leaf/Flower Emblem SVG -->
                  <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-500 group-hover:scale-105">
                    <circle cx="12" cy="12" r="10" stroke-dasharray="3 3"></circle>
                    <path d="M12 2v20M2 12h20M12 12c2.5-3.5 5.5-3.5 8 0-2.5 3.5-5.5 3.5-8 0M12 12c-2.5-3.5-5.5-3.5-8 0 2.5 3.5 5.5 3.5 8 0"></path>
                    <circle cx="12" cy="12" r="3" fill="var(--color-primary)" opacity="0.8"></circle>
                  </svg>
                </div>
                <div>
                  <h3 class="font-serif text-xl font-medium text-[var(--color-foreground)] group-hover:text-[var(--color-primary)] transition-colors">
                    Waroeng Podjok Mangkoes
                  </h3>
                  <p class="mt-1 text-[9px] font-mono uppercase tracking-[0.1em] text-[var(--color-muted)]">Fiksi Fantasi Mistis (WPM SAGA)</p>
                </div>
              </a>
            </div>
          </div>
        ) : (
          <EmptyState
            title="Belum ada tulisan"
            description="Artikel pertama akan segera hadir. Pantau terus ruang ini."
          />
        )
      }
    </section>

    <!-- Discord Community Call-To-Action Banner -->
    <section class="mt-16 pt-8 border-t border-[var(--color-border)]/30" aria-labelledby="discord-heading">
      <DiscordBanner />
    </section>
  </div>
</BaseLayout>
