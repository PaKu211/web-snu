---
import type { GetStaticPaths } from "astro"
import { getCollection } from "astro:content"
import type { CollectionEntry } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import ArticleCard from "@/components/ArticleCard.astro"
import EmptyState from "@/components/EmptyState.astro"
import { collectSeri, seriDescription, seriLabel, sortArtikel } from "@/lib/utils"

export const getStaticPaths = (async () => {
  const all = sortArtikel(await getCollection("artikel"))
  const seri = collectSeri(all)
  return seri.map(({ seri: s }) => ({
    params: { seri: s },
    props: { entries: all.filter((a) => a.data.seri === s) },
  }))
}) satisfies GetStaticPaths

interface Props {
  entries: CollectionEntry<"artikel">[]
}
const { seri } = Astro.params
const { entries } = Astro.props
const label = seriLabel(seri!)
const description = seriDescription(seri!)
---

<BaseLayout title={`Seri: ${label}`} description={description ?? `Artikel dalam seri ${label}.`}>
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[{ label: "Artikel", href: "/artikel" }, { label }]} />

    <header class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-primary)]">Seri</p>
      <h1 class="mt-1 font-serif text-3xl font-semibold sm:text-4xl">{label}</h1>
      {description && <p class="mt-2 max-w-2xl text-[var(--color-muted)]">{description}</p>}
      <p class="mt-2 text-sm text-[var(--color-muted)]">{entries.length} tulisan</p>
    </header>

    {
      entries.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {entries.map((entry) => (
            <ArticleCard entry={entry}  />
          ))}
        </div>
      ) : (
        <EmptyState title="Belum ada tulisan" ctaLabel="Kembali ke Artikel" ctaHref="/artikel" />
      )
    }
  </div>
</BaseLayout>
