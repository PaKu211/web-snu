---
import BaseLayout from "@/layouts/BaseLayout.astro"
---

<BaseLayout title="Halaman Tak Ditemukan" noindex>
  <section class="mx-auto flex min-h-[60vh] max-w-xl flex-col items-center justify-center px-4 py-20 text-center sm:px-6">
    <p class="font-serif text-6xl font-semibold text-[var(--color-primary)]">404</p>
    <h1 class="mt-4 font-serif text-2xl font-semibold">Tersesat di antara kabut</h1>
    <p class="mt-3 text-[var(--color-muted)]">
      Halaman yang kamu cari berada di ruang niskala — tak tampak di sini. Mungkin sudah berpindah
      atau tak pernah ada.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center rounded-md bg-[var(--color-primary)] px-5 py-2.5 text-sm font-semibold text-[var(--color-primary-foreground)] transition-opacity hover:opacity-90"
      >
        Kembali ke Beranda
      </a>
      <a
        href="/artikel"
        class="inline-flex items-center rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-5 py-2.5 text-sm font-semibold text-[var(--color-foreground)] transition-colors hover:bg-[var(--color-surface-2)]"
      >
        Jelajahi Artikel
      </a>
    </div>
  </section>
</BaseLayout>
