---
import type { GetStaticPaths } from "astro"
import { getCollection } from "astro:content"
import type { CollectionEntry } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import ArticleCard from "@/components/ArticleCard.astro"
import EmptyState from "@/components/EmptyState.astro"
import { collectTags, sortArtikel, tagDescription, tagLabel } from "@/lib/utils"

export const getStaticPaths = (async () => {
  const all = sortArtikel(await getCollection("artikel"))
  const tags = collectTags(all)
  return tags.map(({ tag }) => ({
    params: { tag },
    props: { entries: all.filter((a) => a.data.tags.includes(tag)) },
  }))
}) satisfies GetStaticPaths

interface Props {
  entries: CollectionEntry<"artikel">[]
}
const { tag } = Astro.params
const { entries } = Astro.props
const label = tagLabel(tag!)
const description = tagDescription(tag!)
---

<BaseLayout title={`#${label}`} description={description ?? `Artikel dengan tag ${label}.`}>
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[{ label: "Artikel", href: "/artikel" }, { label: `#${label}` }]} />

    <header class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-primary)]">Tag</p>
      <h1 class="mt-1 font-serif text-3xl font-semibold sm:text-4xl">#{label}</h1>
      {description && <p class="mt-2 max-w-2xl text-[var(--color-muted)]">{description}</p>}
      <p class="mt-2 text-sm text-[var(--color-muted)]">{entries.length} tulisan</p>
    </header>

    {
      entries.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {entries.map((entry) => (
            <ArticleCard entry={entry} />
          ))}
        </div>
      ) : (
        <EmptyState title="Belum ada tulisan" ctaLabel="Kembali ke Artikel" ctaHref="/artikel" />
      )
    }
  </div>
</BaseLayout>
