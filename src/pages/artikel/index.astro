---
import { getCollection } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import ArticleFeed from "@/components/ArticleFeed.astro"
import { collectSeri, collectTags, sortArtikel } from "@/lib/utils"

const PAGE_SIZE = 9
const all = sortArtikel(await getCollection("artikel"))
const tags = collectTags(all)
const seri = collectSeri(all)

const lastPage = Math.max(1, Math.ceil(all.length / PAGE_SIZE))
const entries = all.slice(0, PAGE_SIZE)
---

<BaseLayout title="Artikel" description="Semua tulisan dari komunitas Sekala Niskala.">
  <ArticleFeed
    entries={entries}
    tags={tags}
    seri={seri}
    currentPage={1}
    lastPage={lastPage}
    nextUrl={lastPage > 1 ? "/artikel/page/2" : undefined}
  />
</BaseLayout>
